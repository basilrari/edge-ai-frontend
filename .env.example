# Gateway HTTP URL (Next.js bakes this at build time).
# Production (Jetson + Cloudflare tunnel):
NEXT_PUBLIC_GATEWAY_URL=https://edge-ai.basilrari.com
# Local dev with gateway on the same machine:
# NEXT_PUBLIC_GATEWAY_URL=http://localhost:3000

# Optional: MapTiler satellite (native zoom 22). Restart `npm run dev` after editing.
# Free tier: https://www.maptiler.com/cloud/
# If using a protected key, add every origin you use (localhost, Jetson IP, edge-ai.basilrari.com).
MAPTILER_API_KEY=

# Camera MJPEG is proxied at GET ${NEXT_PUBLIC_GATEWAY_URL}/camera/stream (model server on Jetson).

# Legacy alias (requires `npm run build` to take effect):
# NEXT_PUBLIC_MAPTILER_API_KEY=
